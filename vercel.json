{
  "functions": {
    "api/contact.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/api/contact",
      "dest": "/api/contact.php"
    },
    {
      "src": "/api/contact.php",
      "dest": "/api/contact.php"
    },
    {
      "src": "/(index|products|product|about|contact)\\.php",
      "dest": "/$1.php"
    },
    {
      "src": "/(index|products|product|about|contact)",
      "dest": "/$1.php"
    },
    {
      "src": "/",
      "dest": "/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}
