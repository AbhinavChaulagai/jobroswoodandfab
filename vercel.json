{
  "version": 2,
  "builds": [
    { "src": "*.php",                 "use": "vercel-php@0.7.2" },
    { "src": "api/*.php",             "use": "vercel-php@0.7.2" },
    { "src": "admin/*.php",           "use": "vercel-php@0.7.2" },
    { "src": "admin/partials/*.php",  "use": "vercel-php@0.7.2" },
    { "src": "assets/**/*",           "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/assets/(.*)",          "dest": "/assets/$1" },

    { "src": "/api/contact",          "dest": "/api/contact.php" },
    { "src": "/api/upload",           "dest": "/api/upload.php" },

    { "src": "/admin/dashboard",      "dest": "/admin/dashboard.php" },
    { "src": "/admin/product",        "dest": "/admin/product.php" },
    { "src": "/admin/delete",         "dest": "/admin/delete.php" },
    { "src": "/admin/submissions",    "dest": "/admin/submissions.php" },
    { "src": "/admin/logout",         "dest": "/admin/logout.php" },
    { "src": "/admin/",               "dest": "/admin/index.php" },
    { "src": "/admin",                "dest": "/admin/index.php" },

    { "src": "/products",             "dest": "/products.php" },
    { "src": "/product/([0-9]+)",     "dest": "/product.php?id=$1" },
    { "src": "/product",              "dest": "/products.php" },
    { "src": "/about",                "dest": "/about.php" },
    { "src": "/contact",              "dest": "/contact.php" },
    { "src": "/",                     "dest": "/index.php" },
    { "src": "/(.*)",                 "dest": "/index.php" }
  ]
}
